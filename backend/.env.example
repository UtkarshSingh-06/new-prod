# Copy to backend/.env and fill in secrets.

# LLM: openai | groq | ollama
LLM_PROVIDER=openai

# OpenAI: sk-… key. Groq (free): gsk_… key from https://console.groq.com — same var name; gsk_ is auto-routed to Groq.
# Ollama: leave blank (local, no cloud key).
OPENAI_API_KEY=
# Optional explicit model (overrides provider default). OPENAI_MODEL still works for OpenAI.
# LLM_MODEL=

# OpenAI only (optional). Groq/Ollama use built-in base URLs unless you set:
# LLM_BASE_URL=

OPENAI_MODEL=gpt-4o-mini

# SQLite (default local dev)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# JWT — use a long random string in production
JWT_SECRET=change-me
SEED_DEMO_USER=true
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=Demo@12345

# Chroma vector DB (HTTP). Docker Compose sets http://chroma:8000 inside the stack.
CHROMA_URL=http://localhost:8001
# Set true when Chroma is running (e.g. docker compose). Default false = no vector memory.
# Embeddings still use OpenAI; leave false for Groq/Ollama-only setups without an OpenAI key.
ENABLE_CHROMA_MEMORY=false

# LangSmith (optional — traces LLM calls)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=llm-task-assistant
