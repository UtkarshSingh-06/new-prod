# Copy to backend/.env and fill in secrets.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SQLite (default local dev)
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# JWT — use a long random string in production
JWT_SECRET=change-me

# Chroma vector DB (HTTP). Docker Compose sets http://chroma:8000 inside the stack.
CHROMA_URL=http://localhost:8001

# LangSmith (optional — traces LLM calls)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=llm-task-assistant
